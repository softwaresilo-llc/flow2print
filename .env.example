# Global Environment Variables
NODE_ENV=development

# Infrastructure
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/flow2print?schema=public
REDIS_URL=redis://localhost:6379
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# Auth
JWT_SECRET=super-secret-change-me-in-production
JWT_EXPIRES_IN=3600s
REFRESH_TOKEN_SECRET=another-secret-change-me
REFRESH_TOKEN_EXPIRES_IN=7d

# S3 / MinIO
S3_ENDPOINT=localhost
S3_PORT=9000
S3_USE_SSL=false
S3_ACCESS_KEY=minio_admin
S3_SECRET_KEY=minio_password
S3_BUCKET_ASSETS_ORIGINAL=assets-original
S3_BUCKET_ASSETS_DERIVED=assets-derived
S3_BUCKET_PROJECT_SNAPSHOTS=project-snapshots
S3_BUCKET_OUTPUT_PREVIEWS=output-previews
S3_BUCKET_OUTPUT_PROOFS=output-proofs
S3_BUCKET_OUTPUT_PRODUCTION=output-production

# External Ports
PORT_EDGE_API=4000
PORT_IDENTITY_SERVICE=4001
PORT_CATALOG_SERVICE=4002
PORT_TEMPLATE_SERVICE=4003
PORT_PROJECT_SERVICE=4004
PORT_ASSET_SERVICE=4005
PORT_PRODUCTION_SERVICE=4006
PORT_COMMERCE_CONNECTOR_SERVICE=4007

# Frontend URLs
URL_PORTAL_WEB=http://localhost:3000
URL_DESIGNER_WEB=http://localhost:3001
