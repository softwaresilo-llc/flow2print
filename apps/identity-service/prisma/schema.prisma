// apps/identity-service/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id           String       @id // UUIDv7
  slug         String       @unique
  displayName  String
  type         String       @default("public_store") // public_store, b2b_org, internal_demo
  status       String       @default("active")
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  memberships  Membership[]

  @@map("organizations")
}

model User {
  id           String       @id // UUIDv7
  email        String       @unique
  passwordHash String?
  displayName  String?
  status       String       @default("active")
  type         String       @default("customer") // guest, customer, member, service_account
  lastLoginAt  DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  memberships  Membership[]

  @@map("users")
}

model Membership {
  id             String       @id // UUIDv7
  organizationId String
  userId         String
  role           String       @default("member") // org_owner, org_admin, designer, buyer, viewer
  status         String       @default("active")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id])
  user           User         @relation(fields: [userId], references: [id])

  @@unique([organizationId, userId])
  @@map("organization_memberships")
}

model ApiKey {
  id             String       @id // UUIDv7
  organizationId String
  name           String
  keyHash        String       @unique
  scopes         String[]     @default([])
  lastUsedAt     DateTime?
  expiresAt      DateTime?
  createdAt      DateTime     @default(now())

  @@map("api_keys")
}
