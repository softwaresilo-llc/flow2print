{
  "name": "flow2print-platform",
  "private": true,
  "version": "0.1.0",
  "description": "Open source Web2Print platform bootstrap",
  "license": "AGPL-3.0",
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "turbo dev --parallel",
    "infra:up": "docker compose -f infra/compose/docker-compose.yml up -d",
    "infra:down": "docker compose -f infra/compose/docker-compose.yml down",
    "stack:up": "docker compose -f infra/compose/docker-compose.yml up -d --build",
    "stack:down": "docker compose -f infra/compose/docker-compose.yml down --remove-orphans",
    "stack:logs": "docker compose -f infra/compose/docker-compose.yml logs -f --tail=200",
    "build:packages": "pnpm -r --filter './packages/**' build",
    "db:migrate": "pnpm --filter @flow2print/database db:migrate",
    "db:migrate:deploy": "pnpm --filter @flow2print/database db:migrate:deploy",
    "build": "turbo build",
    "check": "turbo check",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "test": "turbo test",
    "format": "prettier --check .",
    "schema:export": "tsx scripts/export-schemas.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@types/node": "^24.5.2",
    "@typescript-eslint/eslint-plugin": "^8.44.0",
    "@typescript-eslint/parser": "^8.44.0",
    "eslint": "^9.36.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.6.2",
    "turbo": "^2.5.6",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.44.0"
  }
}
