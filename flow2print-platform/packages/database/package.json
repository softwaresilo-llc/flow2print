{
  "name": "@flow2print/database",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "prisma generate --schema prisma/schema.prisma && tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint 'src/**/*.ts'",
    "test": "node --test dist/**/*.test.js",
    "db:generate": "prisma generate --schema prisma/schema.prisma",
    "db:push": "prisma db push --schema prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema prisma/schema.prisma",
    "db:migrate:deploy": "prisma migrate deploy --schema prisma/schema.prisma"
  },
  "dependencies": {
    "@flow2print/design-document": "workspace:*",
    "@flow2print/domain": "workspace:*",
    "@flow2print/http-sdk": "workspace:*",
    "@flow2print/pricing-signals": "workspace:*",
    "@flow2print/rendering-engine": "workspace:*",
    "@prisma/client": "^6.5.0"
  },
  "devDependencies": {
    "prisma": "^6.5.0"
  }
}
