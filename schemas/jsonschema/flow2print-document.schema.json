{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://flow2print.dev/schemas/flow2print-document.schema.json",
  "title": "Flow2Print Document",
  "type": "object",
  "required": [
    "schemaVersion",
    "projectId",
    "projectVersionId",
    "tenantId",
    "blueprintVersionId",
    "locale",
    "currency",
    "units",
    "surfaces"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1.0.0"
    },
    "projectId": {
      "type": "string"
    },
    "projectVersionId": {
      "type": "string"
    },
    "tenantId": {
      "type": "string"
    },
    "blueprintVersionId": {
      "type": "string"
    },
    "templateVersionId": {
      "type": [
        "string",
        "null"
      ]
    },
    "locale": {
      "type": "string"
    },
    "currency": {
      "type": "string"
    },
    "units": {
      "const": "mm"
    },
    "surfaces": {
      "type": "array",
      "minItems": 1
    }
  },
  "additionalProperties": true
}

